; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via text for version control.

[application]

config/name="BattleZone Party"
config/description="Local multiplayer 3D party game — connect via WiFi, Bluetooth, or Internet and compete with friends in 5 action-packed mini-games!"
config/version="0.1.0"
config/tags=PackedStringArray("3d", "multiplayer", "mobile", "party")
run/main_scene="res://ui/main_menu/main_menu.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[audio]

[autoload]

ConnectionManager="*res://autoload/connection_manager.gd"
Lobby="*res://autoload/lobby.gd"
GameManager="*res://autoload/game_manager.gd"
AudioManager="*res://autoload/audio_manager.gd"
TutorialManager="*res://ui/tutorial/tutorial_manager.gd"
ChatManager="*res://autoload/chat_manager.gd"
NotificationManager="*res://autoload/notification_manager.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/mode=2
window/stretch/mode="viewport"
window/stretch/aspect="expand"
window/handheld/orientation=6

