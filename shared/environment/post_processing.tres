[sub_resource type="ProceduralSkyMaterial" id="ProceduralSkyMaterial_pp"]
sky_top_color = Color(0.35, 0.55, 0.85, 1)
sky_horizon_color = Color(0.65, 0.75, 0.9, 1)
ground_bottom_color = Color(0.25, 0.28, 0.25, 1)
ground_horizon_color = Color(0.55, 0.6, 0.55, 1)
sun_angle_max = 45.0
sun_curve = 0.1

[sub_resource type="Sky" id="Sky_pp"]
sky_material = SubResource("ProceduralSkyMaterial_pp")
